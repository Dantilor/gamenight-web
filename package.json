{
  "name": "telegram-card-game",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "homepage": "https://dantilor.github.io/telegram-card-game/",
  "scripts": {
    "test": "vitest run",
    "dev": "vite",
    "dev:server": "npm run dev --prefix server",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:server\"",
    "build": "tsc -b && vite build",
    "deploy": "gh-pages -d dist",
    "lint": "eslint .",
    "preview": "vite preview",
    "preview:base": "node scripts/preview-with-base.mjs",
    "preview:ngrok": "vite preview -- --host 0.0.0.0 --port 4173",
    "prepare:comics": "node scripts/prepare-comics.mjs",
    "trim:comics": "python3 scripts/trim-comic-webp.py"
  },
  "dependencies": {
    "@twa-dev/sdk": "^7.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-legacy": "^5.4.0",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.1.0",
    "eslint": "^9.13.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "gh-pages": "^6.3.0",
    "globals": "^15.11.0",
    "sharp": "^0.34.5",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.11.0",
    "vite": "^5.4.10",
    "vite-plugin-image-optimizer": "^2.0.3",
    "vitest": "^4.0.18"
  }
}
